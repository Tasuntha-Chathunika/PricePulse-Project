{
    "manifest_version": 3,
    "name": "PricePulse Tracker",
    "version": "1.0",
    "description": "Track prices directly from your browser",
    "permissions": [
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "http://localhost:5000/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon.png"
    }
}